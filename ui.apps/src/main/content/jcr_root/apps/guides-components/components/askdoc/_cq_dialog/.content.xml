<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="AskDoc"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        granite:class="cmp-form-askdoc-editDialog"
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <tab-1
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Configuration"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <endpoint
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="API endpoint URL for the conversational chat. Receives JSON payload with chat messages and returns markdown responses."
                                        fieldLabel="Chat API Endpoint"
                                        name="./chatEndpoint"/>
                                    <welcomeMessage
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                        fieldDescription="Welcome message displayed when the chat opens. Supports plain text."
                                        fieldLabel="Welcome Message"
                                        name="./welcomeMessage"/>
                                    <placeholder
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="Placeholder text for the chat input field."
                                        fieldLabel="Input Placeholder"
                                        name="./chatPlaceholder"/>
                                    <disclaimerText
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="Disclaimer text shown at the bottom of the chat panel."
                                        fieldLabel="Disclaimer Text"
                                        name="./chatDisclaimerText"/>
                                    <guidelinesLink
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="URL for the Generative AI User Guidelines link."
                                        fieldLabel="Guidelines Link URL"
                                        name="./guidelinesLink"/>
                                </items>
                            </column>
                        </items>
                    </tab-1>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
