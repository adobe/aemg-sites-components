<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Page Feedback"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/tabs"
                    maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <general
                            jcr:primaryType="nt:unstructured"
                            jcr:title="General"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <questionText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="The main question shown to users"
                                    fieldLabel="Question Text"
                                    name="./questionText"
                                    value="Was this page helpful?"/>
                            <positiveButtonText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Label for the positive feedback button"
                                    fieldLabel="Positive Button Text"
                                    name="./positiveButtonText"
                                    value="Yes, thanks"/>
                            <negativeButtonText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Label for the negative feedback button"
                                    fieldLabel="Negative Button Text"
                                    name="./negativeButtonText"
                                    value="Not really"/>
                            <positiveHeading
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Heading shown when user gives positive feedback"
                                    fieldLabel="Positive Feedback Heading"
                                    name="./positiveHeading"
                                    value="We're glad. Tell us how this page helped."/>
                            <negativeHeading
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Heading shown when user gives negative feedback"
                                    fieldLabel="Negative Feedback Heading"
                                    name="./negativeHeading"
                                    value="We're sorry. Can you tell us what didn't work for you?"/>
                            <thankYouMessage
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Message shown after feedback is submitted"
                                    fieldLabel="Thank You Message"
                                    name="./thankYouMessage"
                                    value="Thank you for your feedback. Your response will help improve this page."/>
                        </items>
                    </general>
                    <api
                            jcr:primaryType="nt:unstructured"
                            jcr:title="API Configuration"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <feedbackEndpoint
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="API endpoint URL where feedback data will be submitted"
                                    fieldLabel="Feedback API Endpoint"
                                    name="./feedbackEndpoint"/>
                        </items>
                    </api>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
