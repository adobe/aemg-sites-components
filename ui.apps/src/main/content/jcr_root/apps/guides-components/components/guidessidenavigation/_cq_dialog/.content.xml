<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Guides Side Navigation"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/tabs"
                    maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <productHeader
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Product Header"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <productLogo
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldDescription="Select the product logo image from DAM"
                                    fieldLabel="Product Logo"
                                    mimeTypes="[image/*,image/gif,image/jpeg,image/png,image/webp,image/svg+xml]"
                                    name="./productLogo"
                                    rootPath="/content/dam"/>
                            <productTitle
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Enter the product title displayed next to the logo"
                                    fieldLabel="Product Title"
                                    name="./productTitle"/>
                            <appLinkText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Enter the link text (e.g. Open app)"
                                    fieldLabel="App Link Text"
                                    name="./appLinkText"/>
                            <appLinkUrl
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Enter the URL for the app link"
                                    fieldLabel="App Link URL"
                                    name="./appLinkUrl"/>
                            <expandAllText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Label text for the expand-all-sections toggle (e.g. Expand all sections). Leave empty to hide the toggle."
                                    fieldLabel="Expand All Toggle Text"
                                    name="./expandAllText"/>
                        </items>
                    </productHeader>
                    <navigation
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Navigation"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <limit
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Total items to show in a level"
                                    fieldLabel="Limit"
                                    name="./limit"
                                    value="1000" />
                            <loadMoreText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldDescription="Load more items button text"
                                    fieldLabel="Load more items text"
                                    name="./loadMoreText"
                                    value="load more..." />
                        </items>
                    </navigation>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
